# ========================================
# Конфигурация Event Booking Frontend
# ========================================

# URL вашего бэкенда
REACT_APP_API_URL=http://localhost:8080

# Режим работы приложения
# true  - использовать встроенные моки (демо-данные)
# false - использовать реальный API
REACT_APP_USE_MOCKS=true

# ========================================
# Примеры конфигурации для разных сценариев
# ========================================

# Вариант 3: Локальный запуск с моками
# REACT_APP_USE_MOCKS=true
# REACT_APP_API_URL=http://localhost:8080

# Вариант 4: Локальный запуск с реальным бэкендом
# REACT_APP_API_URL=http://localhost:8080
# REACT_APP_USE_MOCKS=false

# Docker с реальным бэкендом (Вариант 2)
# REACT_APP_API_URL=http://host.docker.internal:8080
# REACT_APP_USE_MOCKS=false

# Продакшен
# REACT_APP_API_URL=https://your-backend-domain.com
# REACT_APP_USE_MOCKS=false

# ========================================
# Примечания:
# ========================================
# - Для Docker с моками (Вариант 1) переменные не нужны
# - Для локального запуска с моками (Вариант 3) используйте npm run start:mocks
# - Для локального запуска с бэкендом (Вариант 4) используйте npm run start:backend
# - Порт 8080 должен быть свободен для вашего реального бэкенда 